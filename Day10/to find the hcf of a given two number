//to find the hcf of a given two number
#include <stdio.h>
void main()
{
    int a, b, i, hcf;
    printf("Enter two numbers: ");
    scanf("%d%d", &a, &b);
    hcf = 1;
    for(i = 1; i <= a && i <= b; i++)
    {
        if(a % i == 0 && b % i == 0)
        {
            hcf = i;
        }
    }

    printf("HCF = %d", hcf);
}
