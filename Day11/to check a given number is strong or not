//to check a given number is strong or not
#include <stdio.h>
void main()
{
    int n, temp, rem, i, fact, sum = 0;
    printf("Enter a number: ");
    scanf("%d", &n);
    temp = n;

    while(temp > 0)
    {
        rem = temp % 10;
        fact = 1;

        for(i = 1; i <= rem; i++)
        {
            fact = fact * i;
        }

        sum = sum + fact;
        temp = temp / 10;
    }

    if(sum == n)
        printf("%d is a Strong Number", n);
    else
        printf("%d is Not a Strong Number", n);
}
