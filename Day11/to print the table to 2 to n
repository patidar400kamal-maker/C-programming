//to print the table to 2 to n
#include <stdio.h>
void main()
{
    int n, i, j;
    printf("Enter last table number: ");
    scanf("%d", &n);

    for(i = 2; i <= n; i++)
    {
        printf("\nTable of %d\n", i);

        for(j = 1; j <= 10; j++)
        {
            printf("%d x %d = %d\n", i, j, i * j);
        }
    }
}
