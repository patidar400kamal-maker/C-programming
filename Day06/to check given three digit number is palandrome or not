//to check given three digit number is palandrome or not
#include <stdio.h>
void main()
{
    int n, temp, rev = 0, rem;
    printf("Enter a 3-digit number: ");
    scanf("%d", &n);
    temp = n;
    while (n != 0)
    {
        rem = n % 10;
        rev = rev * 10 + rem;
        n = n / 10;
    }
    if (temp == rev)
        printf("Palindrome Number");
    else
        printf("Not a Palindrome Number");
}
