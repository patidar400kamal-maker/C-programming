//to check a given 3 digit number is armstrong or not
#include <stdio.h>
void main()
{
    int n, temp, rem, sum = 0;
    printf("Enter a 3-digit number: ");
    scanf("%d", &n);
    temp = n;
    while (n != 0)
    {
        rem = n % 10;
        sum = sum + (rem * rem * rem);
        n = n / 10;
    }
    if (temp == sum)
        printf("Armstrong Number");
    else
        printf("Not an Armstrong Number");
}
