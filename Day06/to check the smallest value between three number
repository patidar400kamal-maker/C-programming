//to check the smallest value between three number
#include <stdio.h>
void main()
{
    int a, b, c;
    printf("Enter three numbers: ");
    scanf("%d%d%d", &a, &b, &c);

    if(a<=b && a<=c)
        printf("Smallest = %d", a);
    else if(b<=a && b<=c)
        printf("Smallest = %d", b);
    else
        printf("Smallest = %d", c);
}
