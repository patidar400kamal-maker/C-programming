//find the greater between 4 number using nested if else
#include <stdio.h>
void main()
{
    int a, b, c, d;
    printf("Enter four numbers: ");
    scanf("%d %d %d %d", &a, &b, &c, &d);
    if(a > b) {
        if(a > c) {
            if(a > d)
                printf("%d is greatest\n", a);
            else
                printf("%d is greatest\n", d);
        } else {
            if(c > d)
                printf("%d is greatest\n", c);
            else
                printf("%d is greatest\n", d);
        }
    } else {
        if(b > c) {
            if(b > d)
                printf("%d is greatest\n", b);
            else
                printf("%d is greatest\n", d);
        } else {
            if(c > d)
                printf("%d is greatest\n", c);
            else
                printf("%d is greatest\n", d);
        }
    }
}
