//To calculate the parameter and area of square
#include <stdio.h>
void main() 
{
    float side, perimeter, area;
    printf("Enter the side of the square: ");
    scanf("%f", &side);
    perimeter = 4 * side;
    area = side * side;
    printf("Perimeter of the square = %.2f\n", perimeter);
    printf("Area of the square = %.2f\n", area);
}
