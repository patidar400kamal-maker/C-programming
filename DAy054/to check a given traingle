//to check given traingle
#include <stdio.h>
void main() 
{
    int a, b, c;
    printf("Enter three sides of the triangle: ");
    scanf("%d %d %d", &a, &b, &c);
    if (a + b > c && a + c > b && b + c > a) 
    {
        printf("Valid Triangle\n");
    } 
   else 
    {
        printf("Invalid Triangle\n");
    }
}
